.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: calc(116rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(31, 63, 52, 0.1);
  background: #fffefa;
  box-shadow: 0 -12rpx 34rpx rgba(18, 31, 27, 0.12);
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 116rpx;
}

.tab-item.active {
  background: #eef6f2;
}

.tab-icon {
  display: block;
  width: 46rpx;
  height: 46rpx;
  margin: 0 auto 7rpx;
}

.tab-item.active .tab-icon {
  transform: translateY(-2rpx);
}

.tab-text {
  color: #697970;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.1;
  text-align: center;
}

.tab-item.active .tab-text {
  color: #1b5f52;
}

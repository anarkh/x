.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: calc(116rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(26, 46, 41, 0.09);
  background: rgba(251, 252, 250, 0.98);
  box-shadow: 0 -18rpx 40rpx rgba(18, 31, 27, 0.1);
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 116rpx;
}

.tab-item.active {
  background: rgba(31, 102, 88, 0.06);
}

.tab-icon {
  display: block;
  width: 50rpx;
  height: 50rpx;
  margin: 0 auto 8rpx;
}

.tab-item.active .tab-icon {
  transform: translateY(-2rpx);
}

.tab-text {
  color: #66736d;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.1;
  text-align: center;
}

.tab-item.active .tab-text {
  color: #1b5f52;
}

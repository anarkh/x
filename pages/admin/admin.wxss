.admin-page {
  padding-bottom: calc(146rpx + env(safe-area-inset-bottom));
}

.admin-head {
  position: relative;
  padding: 16rpx 0 2rpx;
}

.head-rule {
  width: 106rpx;
  height: 8rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #e56d3f, #1f6658);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.summary-card {
  padding: 24rpx 10rpx;
  background: rgba(255, 255, 255, 0.98);
  text-align: center;
}

.summary-card.urgent {
  border-color: rgba(229, 109, 63, 0.2);
  background: linear-gradient(135deg, #fff7f2, #ffffff);
}

.metric {
  color: #1b5f52;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.05;
}

.urgent .metric {
  color: #c84c30;
}

.search-panel {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.98);
}

.search-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 14rpx;
  align-items: center;
}

.search-input {
  min-width: 0;
  height: 74rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(26, 46, 41, 0.12);
  border-radius: 8rpx;
  background: #fbfcfa;
  color: #17201d;
  font-size: 26rpx;
  box-sizing: border-box;
}

.clear-search {
  max-width: 112rpx;
  height: 74rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  background: #eef1ef;
  color: #5f6f68;
  font-size: 24rpx;
  font-weight: 900;
}

.admin-filter-bar {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #40504a;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-chip.active {
  border-color: rgba(31, 102, 88, 0.32);
  background: #1b5f52;
  color: #ffffff;
}

.queue-head {
  gap: 20rpx;
  margin-top: 8rpx;
}

.queue-head > view {
  min-width: 0;
}

.admin-card {
  padding: 26rpx;
  background: rgba(255, 255, 255, 0.98);
}

.card-head {
  align-items: flex-start;
  gap: 18rpx;
}

.admin-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.post-id {
  flex-shrink: 0;
  color: #8a9891;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.admin-title {
  margin-top: 18rpx;
  margin-bottom: 8rpx;
}

.admin-body {
  color: #334941;
  font-size: 26rpx;
  line-height: 1.5;
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(26, 46, 41, 0.08);
  border-bottom: 1rpx solid rgba(26, 46, 41, 0.08);
}

.meta-label {
  margin-bottom: 6rpx;
  color: #84908b;
  font-size: 21rpx;
  font-weight: 900;
}

.meta-value {
  color: #22302c;
  font-size: 25rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.signal-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.signal-item {
  padding: 18rpx 10rpx;
  border-radius: 8rpx;
  background: #edf4f1;
  text-align: center;
}

.signal-item.warn {
  background: #fff1d7;
}

.signal-item.danger {
  background: #ffe8e2;
}

.signal-number {
  color: #1b5f52;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.signal-item.warn .signal-number {
  color: #915709;
}

.signal-item.danger .signal-number {
  color: #a73527;
}

.admin-actions {
  gap: 16rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.admin-actions button {
  max-width: 100%;
}

.resolve-button {
  height: 66rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 8rpx;
  background: #e6f2ee;
  color: #1b5f52;
  font-size: 26rpx;
  font-weight: 800;
}

.hide-button {
  height: 66rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(167, 53, 39, 0.14);
  border-radius: 8rpx;
  background: #ffe8e2;
  color: #a73527;
  font-size: 26rpx;
  font-weight: 800;
}

.empty-panel {
  padding: 34rpx;
}

.empty-title {
  margin-bottom: 10rpx;
  color: #16231f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.admin-page {
  padding-bottom: calc(146rpx + env(safe-area-inset-bottom));
}

.admin-head {
  position: relative;
  padding: 16rpx 0 2rpx;
}

.head-rule {
  width: 106rpx;
  height: 8rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #d7673f, #1f6658);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.summary-card {
  padding: 24rpx 10rpx;
  background: #fffefa;
  text-align: center;
}

.summary-card.urgent {
  border-color: rgba(215, 103, 63, 0.2);
  background: linear-gradient(135deg, #fff6ef, #fffefa);
}

.metric {
  color: #1b5f52;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.05;
}

.urgent .metric {
  color: #b94f34;
}

.feedback-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-head {
  gap: 20rpx;
}

.section-head > view {
  min-width: 0;
}

.feedback-count {
  flex-shrink: 0;
  color: #1b5f52;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.feedback-admin-card {
  padding: 24rpx;
  background: #fffefa;
}

.feedback-card-head {
  align-items: flex-start;
  gap: 18rpx;
}

.feedback-body {
  margin-top: 16rpx;
  color: #2e423a;
  font-size: 28rpx;
  line-height: 1.52;
}

.feedback-meta {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(26, 46, 41, 0.08);
  color: #697970;
  font-size: 24rpx;
  line-height: 1.4;
}

.search-panel {
  padding: 20rpx;
  background: #fffefa;
}

.search-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 14rpx;
  align-items: center;
}

.search-input {
  min-width: 0;
  height: 74rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(26, 46, 41, 0.12);
  border-radius: 14rpx;
  background: #fbfaf4;
  color: #14211d;
  font-size: 26rpx;
  box-sizing: border-box;
}

.clear-search {
  max-width: 112rpx;
  height: 74rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f0eee7;
  color: #697970;
  font-size: 24rpx;
  font-weight: 900;
}

.admin-filter-bar {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.filter-chip {
  display: inline-flex;
  flex: 1 1 146rpx;
  min-width: 0;
  height: 52rpx;
  padding: 0 10rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 999rpx;
  background: rgba(255, 254, 250, 0.82);
  color: #3e5149;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.filter-chip.active {
  border-color: rgba(31, 102, 88, 0.32);
  background: #1f6658;
  color: #ffffff;
}

.queue-head {
  gap: 20rpx;
  margin-top: 8rpx;
}

.queue-head > view {
  min-width: 0;
}

.admin-card {
  padding: 20rpx;
  background: #fffefa;
}

.card-head {
  align-items: flex-start;
  gap: 18rpx;
}

.admin-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.post-id {
  flex-shrink: 0;
  color: #8a9891;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.admin-title {
  margin-top: 14rpx;
  margin-bottom: 6rpx;
  font-size: 29rpx;
  line-height: 1.22;
}

.admin-body {
  color: #2e423a;
  font-size: 24rpx;
  line-height: 1.36;
  max-height: 66rpx;
  overflow: hidden;
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx 14rpx;
  margin-top: 16rpx;
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(26, 46, 41, 0.08);
  border-bottom: 1rpx solid rgba(26, 46, 41, 0.08);
}

.meta-label {
  margin-bottom: 3rpx;
  color: #84908b;
  font-size: 20rpx;
  font-weight: 900;
}

.meta-value {
  color: #2e423a;
  font-size: 23rpx;
  line-height: 1.28;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.signal-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 14rpx;
}

.signal-item {
  padding: 12rpx 8rpx;
  border-radius: 14rpx;
  background: #eaf4ef;
  text-align: center;
}

.signal-item.warn {
  background: #fff2da;
}

.signal-item.danger {
  background: #ffe9e2;
}

.signal-number {
  color: #1b5f52;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.1;
}

.signal-item.warn .signal-number {
  color: #915709;
}

.signal-item.danger .signal-number {
  color: #a73527;
}

.admin-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
}

.admin-actions button {
  flex: 1 1 0;
  min-width: 0;
  max-width: none;
  height: 58rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  line-height: 58rpx;
  white-space: nowrap;
}

.resolve-button {
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  background: #eaf4ef;
  color: #1b5f52;
  font-weight: 800;
}

.hide-button {
  border: 1rpx solid rgba(167, 53, 39, 0.14);
  background: #ffe9e2;
  color: #a73527;
  font-weight: 800;
}

.empty-panel {
  padding: 34rpx;
}

.empty-title {
  margin-bottom: 10rpx;
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

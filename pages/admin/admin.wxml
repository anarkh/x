<view wx:if="{{authorized}}" class="page admin-page stack">
  <view class="admin-head">
    <view class="head-rule"></view>
    <view class="title">管理控制台</view>
    <view class="muted">仅管理员可见 · {{stats.needsReview}} 条待处理 · {{stats.feedback}} 条反馈</view>
  </view>

  <view class="summary-grid">
    <view class="panel summary-card urgent">
      <view class="metric">{{stats.needsReview}}</view>
      <view class="muted">待处理</view>
    </view>
    <view class="panel summary-card">
      <view class="metric">{{stats.reported}}</view>
      <view class="muted">有举报</view>
    </view>
    <view class="panel summary-card">
      <view class="metric">{{stats.stale}}</view>
      <view class="muted">疑似过时</view>
    </view>
    <view class="panel summary-card">
      <view class="metric">{{stats.hidden}}</view>
      <view class="muted">已隐藏</view>
    </view>
  </view>

  <view class="feedback-section">
    <view class="section-head row between">
      <view>
        <view class="section-title">用户反馈</view>
        <view class="muted">来自“我的”页反馈入口</view>
      </view>
      <text class="feedback-count">{{feedbacks.length}}</text>
    </view>

    <view wx:if="{{!feedbacks.length && !feedbackError}}" class="panel empty-panel">
      <view class="empty-title">还没有用户反馈</view>
      <view class="muted">用户提交后会显示在这里。</view>
    </view>

    <view wx:if="{{feedbackError}}" class="panel empty-panel">
      <view class="empty-title">反馈读取失败</view>
      <view class="muted">{{feedbackError}}</view>
    </view>

    <view wx:for="{{feedbacks}}" wx:key="id" class="panel feedback-admin-card">
      <view class="row between feedback-card-head">
        <view class="row admin-tags">
          <text class="tag">{{item.typeText}}</text>
          <text class="tag neutral">{{item.createdText}}</text>
        </view>
        <text class="post-id">{{item.id}}</text>
      </view>
      <view class="feedback-body">{{item.body}}</view>
      <view class="feedback-meta">{{item.nickname}} · {{item.contactText}}</view>
    </view>
  </view>

  <view class="panel search-panel">
    <view class="search-row">
      <input
        class="search-input"
        confirm-type="search"
        placeholder="搜索标题、地点、发布者、ID"
        value="{{query}}"
        bindinput="onSearchInput"
      />
      <button wx:if="{{query}}" class="clear-search" bindtap="clearSearch">清空</button>
    </view>
    <view class="admin-filter-bar">
      <button
        wx:for="{{filterOptions}}"
        wx:key="value"
        class="filter-chip {{activeFilter === item.value ? 'active' : ''}}"
        data-filter="{{item.value}}"
        bindtap="changeFilter"
      >
        {{item.label}} {{item.count}}
      </button>
    </view>
  </view>

  <view class="queue-head row between">
    <view>
      <view class="section-title">处置队列</view>
      <view class="muted">按举报和过时风险排序</view>
    </view>
    <button class="ghost-button" bindtap="refresh">刷新</button>
  </view>

  <view wx:if="{{!visiblePosts.length}}" class="panel empty-panel">
    <view class="empty-title">没有匹配内容</view>
    <view class="muted">换个关键词，或切换到“全部”查看完整列表。</view>
  </view>

  <view wx:for="{{visiblePosts}}" wx:key="id" class="panel admin-card">
    <view class="row between card-head">
      <view class="row admin-tags">
        <text class="tag {{item.riskTone}}">{{item.riskText}}</text>
        <text class="tag">{{item.categoryText}}</text>
        <text wx:if="{{item.intentText}}" class="tag neutral">{{item.intentText}}</text>
        <text class="tag {{item.statusTone}}">{{item.statusText}}</text>
      </view>
      <text class="post-id">{{item.id}}</text>
    </view>

    <view class="section-title admin-title">{{item.title}}</view>
    <view class="admin-body">{{item.body}}</view>

    <view class="meta-grid">
      <view>
        <view class="meta-label">地点</view>
        <view class="meta-value">{{item.placeName}}</view>
      </view>
      <view>
        <view class="meta-label">发布者</view>
        <view class="meta-value">{{item.publisher}}</view>
      </view>
      <view>
        <view class="meta-label">发布时间</view>
        <view class="meta-value">{{item.createdText}}</view>
      </view>
      <view>
        <view class="meta-label">有效期</view>
        <view class="meta-value">{{item.expiryText}}</view>
      </view>
    </view>

    <view class="signal-grid">
      <view class="signal-item">
        <view class="signal-number">{{item.confirmations}}</view>
        <view class="muted">确认</view>
      </view>
      <view class="signal-item {{item.staleCount > 0 ? 'warn' : ''}}">
        <view class="signal-number">{{item.staleCount}}</view>
        <view class="muted">过时</view>
      </view>
      <view class="signal-item {{item.reportCount > 0 ? 'danger' : ''}}">
        <view class="signal-number">{{item.reportCount}}</view>
        <view class="muted">举报</view>
      </view>
    </view>

    <view class="admin-actions">
      <button class="ghost-button" data-id="{{item.id}}" bindtap="openDetail">查看详情</button>
      <button wx:if="{{item.canResolve}}" class="resolve-button" data-id="{{item.id}}" bindtap="resolve">关闭</button>
      <button wx:if="{{item.canHide}}" class="hide-button" data-id="{{item.id}}" bindtap="hide">隐藏</button>
    </view>
  </view>
</view>

<view wx:else class="page admin-page stack">
  <view class="panel empty-panel">
    <view class="empty-title">需要管理员登录</view>
    <view class="muted">请先到“我的”页面校验管理员身份。</view>
  </view>
</view>

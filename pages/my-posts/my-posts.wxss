.list-page {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.page-head {
  position: relative;
  padding: 22rpx 0 12rpx;
}

.stat-panel {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 28rpx 0;
  background: rgba(255, 255, 255, 0.98);
  text-align: center;
}

.metric {
  color: #1b5f52;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.08;
}

.stat-item + .stat-item {
  border-left: 1rpx solid rgba(26, 46, 41, 0.1);
}

.empty-panel {
  padding: 30rpx;
}

.empty-title {
  margin-bottom: 8rpx;
  color: #16231f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.empty-action {
  margin-top: 24rpx;
}

.compact-post {
  padding: 26rpx;
  background: rgba(255, 255, 255, 0.98);
}

.compact-post:active {
  opacity: 0.76;
}

.compact-layout.with-thumb {
  display: grid;
  grid-template-columns: 116rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: start;
}

.compact-main {
  min-width: 0;
}

.compact-thumb {
  width: 116rpx;
  height: 116rpx;
  border-radius: 8rpx;
  background: #eef1ef;
}

.post-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.compact-title {
  margin-top: 14rpx;
  margin-bottom: 8rpx;
  color: #16231f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.28;
}

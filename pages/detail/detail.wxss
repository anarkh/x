.page.stack {
  padding-bottom: 140rpx;
}

.hero {
  position: relative;
  padding: 32rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(215, 103, 63, 0.12), rgba(215, 103, 63, 0) 48%),
    linear-gradient(180deg, #fffefa, #f8f4ec);
  border-color: rgba(31, 63, 52, 0.12);
  box-shadow: 0 14rpx 38rpx rgba(23, 32, 29, 0.08);
}

.hero-kicker {
  position: relative;
  z-index: 1;
  align-self: flex-start;
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf4ef;
  color: #1f6658;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.35;
}

.hero .title {
  position: relative;
  z-index: 1;
  color: #14211d;
}

.hero .body {
  position: relative;
  z-index: 1;
  color: #263831;
}

.hero .muted {
  position: relative;
  z-index: 1;
  color: #697970;
}

.hero-grid {
  position: absolute;
  right: -58rpx;
  top: -48rpx;
  width: 320rpx;
  height: 230rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.14);
  background:
    linear-gradient(90deg, rgba(31, 102, 88, 0.07) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(31, 102, 88, 0.07) 1rpx, transparent 1rpx);
  background-size: 28rpx 28rpx;
  transform: rotate(-8deg);
}

.body {
  font-size: 30rpx;
  line-height: 1.58;
}

.detail-images {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.detail-images.single {
  grid-template-columns: minmax(0, 1fr);
}

.detail-image {
  width: 100%;
  height: 154rpx;
  border-radius: 14rpx;
  background: #f0eee7;
}

.detail-images.single .detail-image {
  height: 360rpx;
}

.publisher-meta-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 2rpx;
}

.publisher-profile {
  display: flex;
  align-items: center;
  flex: 0 1 45%;
  min-width: 0;
}

.publisher-avatar {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #eaf4ef;
}

.publisher-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f6658;
  font-size: 22rpx;
  font-weight: 900;
}

.publisher-name {
  margin-left: 12rpx;
  min-width: 0;
  overflow: hidden;
  color: #28584e;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-meta {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.publish-success {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 20rpx;
  align-items: center;
  padding: 26rpx;
  border-color: rgba(215, 103, 63, 0.18);
  background: linear-gradient(135deg, #fff6ef, #fffefa);
}

.success-title {
  margin-bottom: 8rpx;
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.success-actions {
  gap: 12rpx;
}

.share-button {
  width: 128rpx;
  max-width: 128rpx;
  height: 66rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #d7673f, #b94f34);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.trust-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  align-items: stretch;
}

.trust-button {
  width: 100%;
  min-width: 0;
  height: 70rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 70rpx;
  white-space: nowrap;
}

.trust-confirm {
  color: #ffffff;
  background: linear-gradient(135deg, #143e37, #1f6658);
  box-shadow: 0 14rpx 26rpx rgba(31, 102, 88, 0.18);
}

.trust-stale {
  border: 1rpx solid rgba(185, 121, 31, 0.18);
  color: #8a560c;
  background: linear-gradient(135deg, #fff2da, #fff9ee);
}

.trust-report {
  border: 1rpx solid rgba(167, 53, 39, 0.14);
  color: #a73527;
  background: linear-gradient(135deg, #ffe9e2, #fff4ef);
}

.action-count {
  margin-left: 8rpx;
  font-size: 25rpx;
}

.trust-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(22, 49, 42, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 254, 250, 0.82);
  color: #697970;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.resolve-row {
  display: flex;
}

.resolve-button {
  width: 100%;
  height: 70rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #d7673f, #b94f34);
  box-shadow: 0 14rpx 26rpx rgba(167, 66, 40, 0.18);
  font-weight: 900;
  font-size: 26rpx;
  line-height: 70rpx;
}

.disabled-action {
  opacity: 0.58;
  box-shadow: none;
}

.comments-panel {
  padding: 28rpx;
}

.comments-head {
  align-items: flex-start;
  gap: 18rpx;
}

.comment-input {
  width: 100%;
  min-height: 136rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.16);
  border-radius: 14rpx;
  background: #fbfaf4;
  color: #14211d;
  font-size: 28rpx;
  line-height: 1.45;
}

.floating-comment-button {
  position: fixed;
  right: 28rpx;
  bottom: calc(34rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 168rpx;
  height: 76rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #143e37, #1f6658);
  box-shadow: 0 18rpx 34rpx rgba(23, 32, 29, 0.24);
  font-size: 27rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.comment-dialog-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  padding: 0 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(16, 25, 22, 0.46);
}

.comment-dialog {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx;
  border-radius: 16rpx 16rpx 0 0;
  background: #fffefa;
  box-shadow: 0 -18rpx 44rpx rgba(16, 25, 22, 0.2);
}

.dialog-head {
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.dialog-close {
  width: 112rpx;
  height: 58rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  line-height: 58rpx;
}

.comment-form-footer {
  margin-top: 16rpx;
  gap: 18rpx;
}

.comment-submit {
  width: 132rpx;
  height: 64rpx;
  font-size: 26rpx;
  line-height: 64rpx;
  box-shadow: 0 12rpx 24rpx rgba(31, 102, 88, 0.2);
}

.comment-locked,
.comment-empty {
  padding: 24rpx;
  border-radius: 14rpx;
  background: #f7f3ea;
  color: #697970;
  font-size: 25rpx;
  line-height: 1.5;
  text-align: center;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comment-item {
  padding: 20rpx 0 0;
  border-top: 1rpx solid rgba(26, 46, 41, 0.08);
}

.comment-meta {
  align-items: flex-start;
  gap: 16rpx;
}

.comment-author {
  min-width: 0;
  gap: 10rpx;
}

.comment-name {
  max-width: 360rpx;
  overflow: hidden;
  color: #14211d;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.comment-badge {
  flex: 0 0 auto;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: #eaf4ef;
  color: #1b5f52;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.4;
}

.comment-body {
  margin-top: 10rpx;
  color: #2e423a;
  font-size: 28rpx;
  line-height: 1.56;
  word-break: break-all;
}

.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
}

.loading-mark {
  width: 54rpx;
  height: 54rpx;
  border: 6rpx solid rgba(31, 102, 88, 0.16);
  border-top-color: #1f6658;
  border-radius: 999rpx;
  animation: detail-spin 850ms linear infinite;
}

@keyframes detail-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

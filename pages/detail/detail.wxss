.hero {
  position: relative;
  padding: 32rpx;
  overflow: hidden;
  background: #17231f;
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: 0 18rpx 52rpx rgba(23, 32, 29, 0.18);
}

.hero .title,
.hero .body {
  color: #f7fbf7;
}

.hero .muted {
  color: rgba(247, 251, 247, 0.68);
}

.hero-grid {
  position: absolute;
  right: -80rpx;
  top: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border: 1rpx solid rgba(229, 109, 63, 0.22);
  border-radius: 50%;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(255, 255, 255, 0.06) 1rpx, transparent 1rpx);
  background-size: 28rpx 28rpx;
}

.body {
  font-size: 30rpx;
  line-height: 1.55;
}

.mini-map {
  width: 100%;
  height: 340rpx;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 36rpx rgba(23, 32, 29, 0.12);
}

.metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 28rpx 0;
  text-align: center;
}

.metric-item {
  position: relative;
}

.metric-item + .metric-item {
  border-left: 1rpx solid rgba(26, 46, 41, 0.1);
}

.metric {
  font-size: 46rpx;
  font-weight: 800;
  color: #1f6658;
  line-height: 1.1;
}

.actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.danger-button {
  height: 88rpx;
  border: 1rpx solid rgba(167, 53, 39, 0.14);
  border-radius: 8rpx;
  color: #a73527;
  background: #ffe8e2;
  font-weight: 900;
  font-size: 30rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
}

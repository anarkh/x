<view wx:if="{{loading}}" class="page empty">
  <view class="loading-mark"></view>
  <view class="title">正在加载</view>
  <view class="muted">正在读取任务详情</view>
</view>

<view wx:elif="{{post}}" class="page stack">
  <view class="panel hero stack">
    <view class="hero-grid"></view>
    <view class="row between">
      <view class="row hero-tags">
        <text class="tag">{{post.categoryText}}</text>
        <text wx:if="{{post.intentText}}" class="tag neutral">{{post.intentText}}</text>
        <text wx:if="{{post.status !== 'active'}}" class="tag {{post.status === 'stale' ? 'warn' : ''}} {{post.status === 'resolved' ? 'done' : ''}} {{post.status === 'expired' ? 'neutral' : ''}}">{{post.statusText}}</text>
      </view>
      <text class="muted">{{post.expiryText}}</text>
    </view>
    <view class="title">{{post.title}}</view>
    <view class="body">{{post.body}}</view>
    <view wx:if="{{post.imageUrls.length}}" class="detail-images {{post.imageUrls.length === 1 ? 'single' : ''}}">
      <image
        wx:for="{{post.imageUrls}}"
        wx:key="*this"
        class="detail-image"
        src="{{item}}"
        mode="aspectFill"
        lazy-load="{{true}}"
        data-index="{{index}}"
        bindtap="previewImage"
      />
    </view>
    <view class="muted">{{post.placeName}} · {{post.distanceText}} · {{post.createdText}}</view>
  </view>

  <view wx:if="{{showPublishSuccess}}" class="panel publish-success">
    <view>
      <view class="success-title">已发布到{{appInfo.shortName}}</view>
      <view class="muted">转发给附近的人，能更快获得确认、更新或关闭。</view>
    </view>
    <view class="row success-actions">
      <button class="share-button" open-type="share">转发</button>
    </view>
  </view>

  <map
    class="mini-map"
    latitude="{{post.latitude}}"
    longitude="{{post.longitude}}"
    scale="16"
    markers="{{markers}}"
  />

  <view class="panel metrics">
    <view class="metric-item">
      <view class="metric">{{post.confirmations}}</view>
      <view class="muted">{{post.confirmationHint}}</view>
    </view>
    <view class="metric-item">
      <view class="metric">{{post.staleCount}}</view>
      <view class="muted">过时</view>
    </view>
    <view class="metric-item">
      <view class="metric">{{post.reportCount}}</view>
      <view class="muted">举报</view>
    </view>
  </view>

  <view wx:if="{{post.canReact}}" class="actions {{post.canShowResolve ? 'with-resolve' : 'without-resolve'}}">
    <button wx:if="{{post.canShowResolve}}" class="primary-button resolve-button" bindtap="resolve">{{post.resolveText}}</button>
    <button class="primary-button {{post.confirmedByMe ? 'disabled-action' : ''}}" disabled="{{post.confirmedByMe}}" data-action="confirm" bindtap="react">{{post.confirmedByMe ? '已确认' : '确认有效'}}</button>
    <button class="secondary-button {{post.staledByMe ? 'disabled-action' : ''}}" disabled="{{post.staledByMe}}" data-action="stale" bindtap="react">{{post.staledByMe ? '已标记过时' : '标记过时'}}</button>
    <button class="danger-button {{post.reportedByMe ? 'disabled-action' : ''}}" disabled="{{post.reportedByMe}}" data-action="report" bindtap="react">{{post.reportedByMe ? '已举报' : '举报'}}</button>
  </view>
</view>

<view wx:else class="page empty">
  <view class="title">任务不存在</view>
  <button class="primary-button" bindtap="goHome">返回地图</button>
</view>

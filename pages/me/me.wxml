<view class="page me-page stack">
  <view class="profile-panel">
    <view class="profile-grid"></view>
    <view class="avatar" bindtap="revealAdminLogin">{{avatarText}}</view>
    <view class="profile-copy">
      <view class="profile-kicker">本机身份</view>
      <view class="profile-name">{{user.nickname}}</view>
      <view class="profile-meta">{{identityText}} · 数据保存在本机</view>
    </view>
  </view>

  <view class="panel auth-card">
    <view>
      <view class="section-title">{{isGuest ? '登录后记录你的发布' : '当前身份'}}</view>
      <view class="muted">{{isGuest ? '游客可以浏览和发布；登录后会用你的昵称标记本机发布。' : appInfo.name}}</view>
    </view>
    <button wx:if="{{isGuest}}" class="login-button" loading="{{loggingIn}}" disabled="{{loggingIn}}" bindtap="loginUser">{{loggingIn ? '登录中' : '微信登录'}}</button>
    <button wx:else class="ghost-button" bindtap="logoutUser">退出</button>
  </view>

  <view wx:if="{{showAdminLogin && !isAdmin}}" class="panel admin-login-card">
    <view>
      <view class="section-title">管理员入口</view>
      <view class="muted">校验当前微信身份后，底部才会显示“管理”tab。</view>
    </view>
    <view class="admin-login-row">
      <button class="admin-login-button" loading="{{checkingAdmin}}" disabled="{{checkingAdmin}}" bindtap="loginAdmin">{{checkingAdmin ? '校验中' : '校验身份'}}</button>
    </view>
  </view>

  <view wx:if="{{isAdmin}}" class="panel admin-ready-card" bindtap="goAdmin">
    <view>
      <view class="section-title">管理权限已开启</view>
      <view class="muted">可以巡检举报、过时、隐藏和已关闭内容。</view>
    </view>
    <view class="admin-ready-arrow"></view>
  </view>

  <view class="panel feedback-entry" bindtap="goFeedback">
    <view class="feedback-entry-title">反馈建议</view>
    <view class="feedback-entry-arrow"></view>
  </view>

  <view class="panel stat-panel">
    <view wx:for="{{stats}}" wx:key="label" class="stat-item">
      <view class="metric">{{item.value}}</view>
      <view class="muted">{{item.label}}</view>
    </view>
  </view>

  <view class="panel profile-link-card" bindtap="goMyPosts">
    <view>
      <view class="profile-link-title">我的发布</view>
      <view class="muted">{{myPostsText}}</view>
    </view>
    <view class="profile-link-arrow"></view>
  </view>

  <view class="panel profile-link-card" bindtap="goActivities">
    <view>
      <view class="profile-link-title">参与记录</view>
      <view class="muted">{{activitiesText}}</view>
    </view>
    <view class="profile-link-arrow"></view>
  </view>
</view>

<view class="page me-page stack">
  <view class="profile-panel">
    <view class="profile-grid"></view>
    <block wx:if="{{!isGuest}}">
      <button wx:if="{{profileNeedsSetup}}" class="avatar-button" open-type="chooseAvatar" bindtap="revealAdminLogin" bindchooseavatar="onChooseAvatar" bindlongpress="revealAdminLogin">
        <image wx:if="{{user.avatarUrl}}" class="avatar avatar-image" src="{{user.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar avatar-add">添加</view>
      </button>
      <view wx:else class="avatar-button" bindtap="revealAdminLogin" bindlongpress="revealAdminLogin">
        <image wx:if="{{user.avatarUrl}}" class="avatar avatar-image" src="{{user.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar">{{avatarText}}</view>
      </view>
    </block>
    <image wx:else class="avatar guest-avatar-image" src="/assets/icons/big-dipper.png" mode="aspectFill" bindtap="revealAdminLogin" />
    <view class="profile-copy">
      <block wx:if="{{!isGuest}}">
        <input wx:if="{{profileNeedsSetup}}" class="profile-name profile-name-input" type="nickname" value="{{profileNicknameValue}}" placeholder="点击添加名称" bindblur="onNicknameBlur" />
        <view wx:else class="profile-name">{{user.nickname}}</view>
      </block>
      <view wx:else class="profile-name">{{displayName}}</view>
      <view wx:if="{{profileNeedsSetup}}" class="profile-guide">点击头像和名称添加微信资料</view>
    </view>
    <button wx:if="{{isGuest}}" class="login-button profile-action" loading="{{loggingIn}}" disabled="{{loggingIn}}" bindtap="loginUser">{{loggingIn ? '登录中' : '微信登录'}}</button>
    <view wx:else class="profile-feedback-button profile-action" bindtap="goFeedback">反馈</view>
  </view>

  <block wx:if="{{showAdminLogin}}">
    <view wx:if="{{!isAdmin}}" class="panel admin-login-card">
      <view>
        <view class="section-title">管理员入口</view>
        <view class="muted">校验当前微信身份后，底部才会显示“管理”tab。</view>
      </view>
      <view class="admin-login-row">
        <button class="admin-login-button" loading="{{checkingAdmin}}" disabled="{{checkingAdmin}}" bindtap="loginAdmin">{{checkingAdmin ? '校验中' : '校验身份'}}</button>
      </view>
      <view wx:if="{{adminCheckText}}" class="admin-check-debug">{{adminCheckText}}</view>
    </view>
  </block>

  <view wx:if="{{isAdmin}}" class="panel admin-ready-card" bindtap="goAdmin">
    <view>
      <view class="section-title">管理权限已开启</view>
      <view class="muted">可以巡检举报、过时、隐藏和已关闭内容。</view>
    </view>
    <view class="admin-ready-arrow"></view>
  </view>

  <view class="panel stat-panel">
    <view wx:for="{{stats}}" wx:key="label" class="stat-item">
      <view class="metric">{{item.value}}</view>
      <view class="muted">{{item.label}}</view>
    </view>
  </view>

  <view class="panel next-panel">
    <view class="next-copy">
      <view class="section-title">{{nextAction.title}}</view>
      <view class="muted">{{nextAction.note}}</view>
    </view>
    <button class="next-action-button" bindtap="handleNextAction">{{nextAction.buttonText}}</button>
  </view>

  <view wx:if="{{recentActivities.length}}" class="panel recent-panel">
    <view class="section-head">
      <view>
        <view class="section-title">最近动态</view>
        <view class="muted">你刚参与过的附近任务</view>
      </view>
      <view class="mini-link" bindtap="goActivities">全部</view>
    </view>
    <view wx:for="{{recentActivities}}" wx:key="activityKey" class="recent-row" data-id="{{item.post.id}}" bindtap="openDetail">
      <view class="activity-mark {{item.tone}}">{{item.label}}</view>
      <view class="recent-main">
        <view class="recent-title">{{item.post.title}}</view>
        <view class="muted">{{item.post.placeName}} · {{item.reactedText}}</view>
      </view>
    </view>
  </view>

  <view class="panel profile-link-card" bindtap="goMyPosts">
    <view>
      <view class="profile-link-title">我的发布</view>
      <view class="muted">{{myPostsText}}</view>
    </view>
    <view class="profile-link-arrow"></view>
  </view>

  <view class="panel profile-link-card" bindtap="goActivities">
    <view>
      <view class="profile-link-title">参与记录</view>
      <view class="muted">{{activitiesText}}</view>
    </view>
    <view class="profile-link-arrow"></view>
  </view>
</view>

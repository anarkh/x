.me-page {
  padding-bottom: calc(146rpx + env(safe-area-inset-bottom));
}

.profile-panel {
  position: relative;
  display: grid;
  grid-template-columns: 104rpx minmax(0, 1fr) auto;
  gap: 22rpx;
  align-items: center;
  min-height: 188rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(215, 103, 63, 0.16), rgba(215, 103, 63, 0) 44%),
    linear-gradient(160deg, #173b33, #12372f);
  box-shadow: 0 18rpx 52rpx rgba(23, 32, 29, 0.18);
  box-sizing: border-box;
}

.profile-grid {
  position: absolute;
  right: -58rpx;
  top: -48rpx;
  width: 320rpx;
  height: 230rpx;
  border: 1rpx solid rgba(215, 103, 63, 0.2);
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(255, 255, 255, 0.06) 1rpx, transparent 1rpx);
  background-size: 28rpx 28rpx;
  transform: rotate(-8deg);
}

.avatar {
  position: relative;
  z-index: 1;
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
  background: #f7fbf7;
  color: #1b5f52;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 104rpx;
  text-align: center;
  box-shadow: 0 14rpx 28rpx rgba(0, 0, 0, 0.14);
  box-sizing: border-box;
}

.avatar-button {
  position: relative;
  z-index: 1;
  width: 104rpx;
  height: 104rpx;
  padding: 0;
  border-radius: 16rpx;
  background: transparent;
  overflow: hidden;
}

.avatar-image {
  display: block;
  border: 4rpx solid rgba(247, 251, 247, 0.9);
}

.avatar-add {
  color: #1b5f52;
  font-size: 24rpx;
  font-weight: 900;
}

.guest-avatar-image {
  display: block;
  border: 4rpx solid rgba(247, 251, 247, 0.86);
}

.profile-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.profile-name {
  margin-top: 8rpx;
  color: #f7fbf7;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.15;
}

.profile-name-input {
  display: block;
  width: 100%;
  height: 62rpx;
  margin-top: 0;
  padding: 0;
  color: #f7fbf7;
  background: transparent;
  box-sizing: border-box;
}

.profile-guide {
  margin-top: 10rpx;
  color: rgba(247, 251, 247, 0.58);
  font-size: 22rpx;
  line-height: 1.35;
}

.admin-login-card,
.admin-ready-card {
  padding: 28rpx;
}

.admin-ready-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 22rpx;
  align-items: center;
}

.login-button {
  max-width: 180rpx;
  height: 68rpx;
  padding: 0 28rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #143e37, #1f6658);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.profile-action {
  position: relative;
  z-index: 1;
  margin: 0;
  justify-self: end;
  white-space: nowrap;
}

.profile-feedback-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 38rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(247, 251, 247, 0.1);
  color: rgba(247, 251, 247, 0.62);
  font-size: 20rpx;
  font-weight: 700;
  line-height: 38rpx;
  box-sizing: border-box;
}

.admin-login-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  border-color: rgba(215, 103, 63, 0.18);
}

.admin-login-row {
  display: flex;
}

.admin-code-input {
  min-width: 0;
  height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(26, 46, 41, 0.12);
  border-radius: 14rpx;
  background: #fbfaf4;
  color: #14211d;
  font-size: 26rpx;
  box-sizing: border-box;
}

.admin-login-button {
  width: 196rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: #d7673f;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.admin-check-debug {
  padding: 18rpx;
  border-radius: 14rpx;
  background: #fff7ed;
  color: #7a3d12;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
  white-space: pre-wrap;
}

.admin-ready-card {
  border-color: rgba(31, 102, 88, 0.18);
  background: linear-gradient(135deg, #f1f8f4, #fffefa);
}

.admin-ready-card:active {
  opacity: 0.76;
}

.admin-ready-arrow {
  width: 24rpx;
  height: 24rpx;
  border-top: 6rpx solid #1b5f52;
  border-right: 6rpx solid #1b5f52;
  transform: rotate(45deg);
}

.profile-link-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 44rpx;
  gap: 18rpx;
  align-items: center;
  min-height: 92rpx;
  padding: 0 28rpx;
  background: #fffefa;
}

.profile-link-card:active {
  opacity: 0.76;
}

.profile-link-title {
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.profile-link-arrow {
  width: 20rpx;
  height: 20rpx;
  border-top: 6rpx solid #1b5f52;
  border-right: 6rpx solid #1b5f52;
  transform: rotate(45deg);
}

.stat-panel {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 28rpx 0;
  background: #fffefa;
  text-align: center;
}

.metric {
  color: #1b5f52;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.08;
}

.stat-item + .stat-item {
  border-left: 1rpx solid rgba(26, 46, 41, 0.1);
}

.next-panel {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 18rpx;
  align-items: center;
  padding: 26rpx 28rpx;
  border-color: rgba(31, 102, 88, 0.18);
  background: #fffefa;
}

.next-copy {
  min-width: 0;
}

.next-action-button {
  min-width: 132rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #1f6658;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.recent-panel {
  padding: 26rpx 28rpx;
  background: #fffefa;
}

.mini-link {
  flex-shrink: 0;
  color: #1b5f52;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.4;
}

.recent-row {
  display: grid;
  grid-template-columns: 128rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  padding-top: 20rpx;
}

.recent-row:active {
  opacity: 0.76;
}

.recent-main {
  min-width: 0;
}

.recent-title {
  margin-bottom: 6rpx;
  color: #14211d;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.28;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 8rpx;
}

.section-head > view {
  min-width: 0;
}

.empty-panel {
  padding: 30rpx;
}

.empty-title {
  margin-bottom: 8rpx;
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.compact-post {
  padding: 26rpx;
  background: #fffefa;
}

.post-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.compact-title {
  margin-top: 14rpx;
  margin-bottom: 8rpx;
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.28;
}

.activity-card {
  display: grid;
  grid-template-columns: 144rpx 1fr;
  gap: 18rpx;
  align-items: center;
  padding: 24rpx;
  background: #fffefa;
}

.activity-main {
  min-width: 0;
}

.activity-main .compact-title {
  margin-top: 0;
}

.activity-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  background: #f0eee7;
  color: #697970;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
}

.activity-mark.done {
  background: #e4f0e9;
  color: #28584e;
}

.activity-mark.warn {
  background: #fff2da;
  color: #915709;
}

.activity-mark.danger {
  background: #ffe9e2;
  color: #a73527;
}

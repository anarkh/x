.map-page {
  min-height: 100vh;
  background: #0f1d19;
  position: relative;
  overflow: hidden;
}

.task-map {
  width: 100%;
  height: 100vh;
}

.area-card {
  position: absolute;
  left: 24rpx;
  top: 24rpx;
  z-index: 3;
  max-width: 450rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 8rpx;
  background: rgba(248, 250, 247, 0.92);
  box-shadow: 0 16rpx 38rpx rgba(18, 31, 27, 0.18);
  box-sizing: border-box;
}

.area-kicker {
  color: #c84c30;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.2;
}

.area-name {
  margin-top: 8rpx;
  color: #16231f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.18;
}

.area-meta {
  margin-top: 8rpx;
  color: #53625c;
  font-size: 22rpx;
  line-height: 1.35;
}

.map-tool-row {
  position: absolute;
  right: 24rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 3;
  display: grid;
  grid-template-columns: repeat(3, 80rpx);
  gap: 10rpx;
  align-items: center;
  justify-items: center;
}

.map-tool-button {
  position: relative;
  width: 68rpx;
  min-width: 68rpx;
  max-width: 68rpx;
  height: 68rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 50%;
  background: transparent;
  box-shadow: none;
}

.map-tool-button:active {
  opacity: 0.72;
}

.clear-tool-button {
  background: transparent;
}

.tool-icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  color: #5f6c66;
  box-sizing: border-box;
  filter: drop-shadow(0 2rpx 2rpx rgba(255, 255, 255, 0.78));
}

.tool-symbol {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  color: #5f6c66;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1;
  filter: drop-shadow(0 2rpx 2rpx rgba(255, 255, 255, 0.78));
}

.refresh-symbol {
  transform: translateY(-1rpx);
}

.refresh-symbol.spinning {
  animation: refresh-spin 520ms ease-out;
}

@keyframes refresh-spin {
  from {
    transform: translateY(-1rpx) rotate(0deg);
  }
  to {
    transform: translateY(-1rpx) rotate(360deg);
  }
}

.target-tool {
  width: 38rpx;
  height: 38rpx;
  border: 5rpx solid #5f6c66;
  border-radius: 50%;
}

.target-tool::before,
.target-tool::after {
  content: "";
  position: absolute;
  background: #5f6c66;
}

.target-tool::before {
  left: 50%;
  top: -10rpx;
  width: 5rpx;
  height: 58rpx;
  transform: translateX(-50%);
}

.target-tool::after {
  left: -10rpx;
  top: 50%;
  width: 58rpx;
  height: 5rpx;
  transform: translateY(-50%);
}

.target-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 1;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #5f6c66;
  transform: translate(-50%, -50%);
}

.discover-tool-button {
  background: rgba(200, 76, 48, 0.94);
  box-shadow: 0 8rpx 22rpx rgba(125, 47, 31, 0.2);
}

.discover-tool-button:active {
  background: rgba(229, 109, 63, 0.96);
  opacity: 1;
}

.discover-tool-button .tool-icon {
  filter: none;
}

.search-tool {
  width: 36rpx;
  height: 36rpx;
}

.search-tool::before {
  content: "";
  position: absolute;
  left: 3rpx;
  top: 2rpx;
  width: 21rpx;
  height: 21rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
}

.search-tool::after {
  content: "";
  position: absolute;
  right: 4rpx;
  bottom: 5rpx;
  width: 15rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #ffffff;
  transform: rotate(45deg);
  transform-origin: 100% 50%;
}

.search-spark {
  position: absolute;
  right: 0;
  top: 0;
  width: 9rpx;
  height: 9rpx;
}

.search-spark::before,
.search-spark::after {
  content: "";
  position: absolute;
  left: 4rpx;
  top: 0;
  width: 2rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.search-spark::after {
  transform: rotate(90deg);
}

.map-page .list-fab {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  z-index: 3;
  height: 78rpx;
  min-width: 154rpx;
  width: auto;
  max-width: none;
  margin-left: 0;
  margin-right: 0;
  padding: 0 26rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #e56d3f, #c84c30);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 36rpx rgba(125, 47, 31, 0.34);
}

.selected-card {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  z-index: 4;
  padding: 24rpx;
  background: rgba(248, 250, 247, 0.96);
  box-shadow: 0 20rpx 52rpx rgba(13, 24, 21, 0.22);
}

.selected-head {
  display: grid;
  grid-template-columns: 1fr 52rpx;
  gap: 16rpx;
  align-items: start;
}

.selected-main {
  min-width: 0;
}

.selected-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.selected-title {
  color: #14231f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-meta {
  margin-top: 10rpx;
  color: #66736d;
  font-size: 24rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-actions {
  margin-top: 20rpx;
}

.selected-detail {
  width: 100%;
  height: 76rpx;
  border-radius: 8rpx;
  background: #1f6658;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.selected-close {
  width: 52rpx;
  min-width: 52rpx;
  max-width: 52rpx;
  height: 52rpx;
  border-radius: 8rpx;
  background: #edf0ee;
  color: #66736d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  z-index: 4;
  background: rgba(13, 24, 21, 0.36);
}

.list-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
  height: 62vh;
  padding: 18rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 20rpx 20rpx 0 0;
  background:
    linear-gradient(180deg, #f9fbf8, #eef2ef);
  box-sizing: border-box;
  transform: translateY(104%);
  transition: transform 220ms ease;
  box-shadow: 0 -22rpx 56rpx rgba(12, 22, 19, 0.18);
}

.list-drawer.open {
  transform: translateY(0);
}

.drawer-grip {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  background: #c9d2ce;
}

.drawer-head {
  margin-bottom: 18rpx;
}

.filter-bar {
  width: 100%;
  margin-bottom: 18rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #40504a;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-chip.active {
  border-color: rgba(31, 102, 88, 0.32);
  background: #1f6658;
  color: #ffffff;
}

.post-list {
  height: calc(62vh - 248rpx - env(safe-area-inset-bottom));
}

.post-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.post-content {
  min-width: 0;
}

.post-main {
  display: grid;
  grid-template-columns: 1fr 52rpx;
  gap: 14rpx;
  align-items: center;
}

.post-text {
  min-width: 0;
}

.card-top {
  margin-top: 16rpx;
  margin-bottom: 0;
}

.card-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.post-title {
  color: #14231f;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.28;
}

.post-meta {
  margin-top: 10rpx;
  color: #66736d;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.signals {
  display: grid;
  grid-template-columns: 1.35fr 0.75fr 1fr;
  gap: 8rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(26, 46, 41, 0.08);
  color: #485650;
  font-size: 24rpx;
}

.signals text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-card .mark-button {
  width: 52rpx;
  min-width: 52rpx;
  max-width: 52rpx;
  height: 52rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  background: transparent;
}

.mark-arrow {
  width: 26rpx;
  height: 26rpx;
  border-top: 6rpx solid #1f6658;
  border-right: 6rpx solid #1f6658;
  transform: rotate(45deg);
}

.empty-panel {
  padding: 36rpx 28rpx;
  margin-top: 6rpx;
}

.empty-title {
  margin-bottom: 10rpx;
  color: #16231f;
  font-size: 30rpx;
  font-weight: 900;
}

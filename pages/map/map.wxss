.map-page {
  min-height: 100vh;
  background: #173b33;
  position: relative;
  overflow: hidden;
}

.task-map {
  width: 100%;
  height: 100vh;
}

.map-page.list-open .task-map {
  height: 38vh;
}

.map-tool-row {
  position: absolute;
  right: 24rpx;
  bottom: calc(138rpx + env(safe-area-inset-bottom));
  z-index: 8;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.map-tool-button {
  position: relative;
  width: 76rpx;
  min-width: 76rpx;
  max-width: 76rpx;
  height: 76rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 16rpx;
  background: rgba(255, 254, 250, 0.94);
  box-shadow: 0 12rpx 30rpx rgba(13, 24, 21, 0.16);
  box-sizing: border-box;
}

.map-tool-button:active {
  opacity: 0.72;
}

.clear-tool-button {
  border: 1rpx solid rgba(31, 63, 52, 0.12);
}

.map-tool-icon {
  display: block;
  width: 46rpx;
  height: 46rpx;
  position: absolute;
  left: 15rpx;
  top: 15rpx;
}

.locate-icon {
  width: 52rpx;
  height: 52rpx;
  left: 12rpx;
  top: 12rpx;
}

.discover-tool-button {
  border-color: rgba(215, 103, 63, 0.2);
  background: #d7673f;
  box-shadow: 0 12rpx 28rpx rgba(125, 47, 31, 0.26);
  margin-left: 16rpx;
}

.discover-tool-button:active {
  background: rgba(215, 103, 63, 0.96);
  opacity: 1;
}

.discover-tool-button .map-tool-icon {
  filter: none;
}

.search-icon {
  width: 42rpx;
  height: 42rpx;
  left: 17rpx;
  top: 17rpx;
}

.list-fab {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  z-index: 9;
  width: 146rpx;
  min-width: 146rpx;
  max-width: 146rpx;
  height: 70rpx;
  padding: 0;
  border-radius: 16rpx;
  border: 1rpx solid rgba(31, 63, 52, 0.12);
  background: rgba(255, 254, 250, 0.96);
  box-shadow: 0 12rpx 30rpx rgba(13, 24, 21, 0.16);
  box-sizing: border-box;
}

.list-fab:active {
  opacity: 0.72;
}

.list-fab-line {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 70rpx;
  color: #173b33;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 70rpx;
  text-align: center;
}

.nearby-preview {
  position: absolute;
  left: 24rpx;
  right: 216rpx;
  bottom: calc(138rpx + env(safe-area-inset-bottom));
  z-index: 3;
  padding: 18rpx;
  background: rgba(255, 254, 250, 0.98);
  box-shadow: 0 18rpx 42rpx rgba(13, 24, 21, 0.18);
}

.nearby-preview.with-selected-post {
  right: 24rpx;
}

.nearby-preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.nearby-title-block {
  min-width: 0;
}

.nearby-title {
  color: #14211d;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.nearby-subtitle {
  margin-top: 4rpx;
  overflow: hidden;
  color: #697970;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nearby-open-button {
  flex-shrink: 0;
  width: 74rpx;
  min-width: 74rpx;
  max-width: 74rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: #eaf4ef;
  color: #1b5f52;
  font-size: 22rpx;
  font-weight: 900;
}

.nearby-strip {
  width: 100%;
  margin-top: 14rpx;
  white-space: nowrap;
}

.nearby-item {
  display: inline-flex;
  flex-direction: column;
  width: 236rpx;
  height: 142rpx;
  margin-right: 12rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.14);
  border-radius: 14rpx;
  background: #f7f3ea;
  box-sizing: border-box;
  vertical-align: top;
}

.nearby-item.selected {
  border-color: rgba(215, 103, 63, 0.42);
  background: #fff2da;
}

.nearby-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.nearby-hint {
  flex-shrink: 0;
  color: #1b5f52;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.2;
}

.nearby-distance {
  min-width: 0;
  overflow: hidden;
  color: #d7673f;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nearby-item-title {
  margin-top: 10rpx;
  overflow: hidden;
  color: #14211d;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nearby-item-meta {
  margin-top: 8rpx;
  overflow: hidden;
  color: #697970;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.diagnostic-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 24rpx;
  z-index: 90;
  padding: 22rpx;
  border-radius: 16rpx;
  background: rgba(20, 33, 29, 0.94);
  color: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(12, 22, 19, 0.28);
  box-sizing: border-box;
}

.diagnostic-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.3;
}

.diagnostic-status,
.diagnostic-line {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  line-height: 1.45;
}

.diagnostic-line {
  color: rgba(255, 255, 255, 0.68);
}

.diagnostic-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.diagnostic-action {
  flex: 1;
  height: 58rpx;
  border-radius: 12rpx;
  background: #f0eee7;
  color: #173b33;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.diagnostic-action.primary {
  background: #d7673f;
  color: #ffffff;
}

.selected-card {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(244rpx + env(safe-area-inset-bottom));
  z-index: 4;
  padding: 26rpx;
  border-color: rgba(31, 63, 52, 0.12);
  background: rgba(255, 254, 250, 0.98);
  box-shadow: 0 22rpx 54rpx rgba(13, 24, 21, 0.18);
}

.selected-head {
  display: grid;
  grid-template-columns: 1fr 52rpx;
  gap: 16rpx;
  align-items: start;
}

.selected-head.with-thumb {
  grid-template-columns: 1fr 108rpx 52rpx;
}

.selected-main {
  min-width: 0;
}

.selected-thumb {
  width: 108rpx;
  height: 108rpx;
  border-radius: 14rpx;
  background: #f0eee7;
}

.selected-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.selected-title {
  color: #14211d;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
}

.selected-meta {
  margin-top: 10rpx;
  color: #697970;
  font-size: 24rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-actions {
  margin-top: 20rpx;
}

.selected-detail {
  width: 100%;
  height: 76rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #143e37, #1f6658);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.selected-close {
  width: 52rpx;
  min-width: 52rpx;
  max-width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: #f0eee7;
  color: #697970;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  z-index: 4;
  background: rgba(13, 24, 21, 0.42);
}

.list-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(116rpx + env(safe-area-inset-bottom));
  z-index: 5;
  display: flex;
  flex-direction: column;
  height: calc(100vh - 116rpx - env(safe-area-inset-bottom));
  padding: 18rpx 24rpx 22rpx;
  border-radius: 16rpx 16rpx 0 0;
  background:
    linear-gradient(180deg, #fffefa, #f4f1ea);
  box-sizing: border-box;
  transform: translateY(104%);
  transition: transform 220ms ease;
  box-shadow: 0 -24rpx 58rpx rgba(12, 22, 19, 0.2);
}

.map-page.list-open .list-drawer {
  top: 38vh;
  height: auto;
}

.list-drawer.open {
  transform: translateY(0);
}

.drawer-grip {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  background: #d2d0c7;
}

.drawer-head {
  margin-bottom: 18rpx;
  align-items: flex-start;
  gap: 18rpx;
}

.drawer-title-block {
  min-width: 0;
}

.drawer-head-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.drawer-counter {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 82rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: #eaf4ef;
}

.drawer-counter-value {
  color: #1b5f52;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.drawer-counter-label {
  margin-top: 4rpx;
  color: #697970;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1;
}

.drawer-head .ghost-button {
  height: 64rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.filter-bar {
  width: 100%;
  margin-bottom: 18rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 999rpx;
  background: rgba(255, 254, 250, 0.82);
  color: #3e5149;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-chip.active {
  border-color: rgba(31, 102, 88, 0.32);
  background: #1f6658;
  color: #ffffff;
}

.post-list {
  flex: 1;
  height: 0;
  min-height: 0;
}

.post-card {
  padding: 20rpx 22rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.post-card.selected {
  border-color: rgba(215, 103, 63, 0.42);
  background: #fffaf0;
  box-shadow: 0 14rpx 36rpx rgba(125, 47, 31, 0.12);
}

.post-content {
  min-width: 0;
}

.post-main {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 48rpx;
  gap: 16rpx;
  align-items: start;
}

.post-main.with-thumb {
  grid-template-columns: 104rpx minmax(0, 1fr) 48rpx;
}

.post-thumb {
  width: 104rpx;
  height: 104rpx;
  border-radius: 14rpx;
  background: #f0eee7;
}

.post-text {
  min-width: 0;
}

.post-title-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.post-title {
  max-width: 100%;
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.28;
  word-break: break-all;
}

.post-inline-tags {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 8rpx;
  min-width: 0;
}

.post-inline-tag {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.16);
  border-radius: 999rpx;
  background: #eaf4ef;
  color: #1b5f52;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.post-inline-tag.neutral {
  border-color: rgba(102, 115, 109, 0.18);
  background: #f0eee7;
  color: #697970;
}

.post-inline-tag.warn {
  border-color: rgba(185, 121, 31, 0.2);
  background: #fff2da;
  color: #8a560c;
}

.post-inline-tag.done {
  border-color: rgba(31, 102, 88, 0.18);
  background: #e4f0e9;
  color: #28584e;
}

.post-summary {
  margin-top: 10rpx;
  color: #3d4d47;
  font-size: 25rpx;
  line-height: 1.45;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.post-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 16rpx;
  color: #697970;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.35;
}

.post-counts {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  min-width: 0;
  color: #3d4d47;
}

.post-footer-meta {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-card .mark-button {
  width: 48rpx;
  min-width: 48rpx;
  max-width: 48rpx;
  height: 48rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 12rpx;
  background: rgba(234, 244, 239, 0.92);
  color: #1f6658;
}

.mark-chevron {
  display: block;
  color: #1f6658;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.empty-panel {
  padding: 36rpx 28rpx;
  margin-top: 6rpx;
}

.empty-title {
  margin-bottom: 10rpx;
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
}

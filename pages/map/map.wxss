.map-page {
  min-height: 100vh;
  background: #0f1d19;
  position: relative;
  overflow: hidden;
}

.task-map {
  width: 100%;
  height: 100vh;
}

.map-page .refresh-fab,
.map-page .locate-fab {
  position: absolute;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 3;
  width: 76rpx;
  min-width: 76rpx;
  max-width: 76rpx;
  height: 76rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.map-page .refresh-fab {
  right: 112rpx;
}

.map-page .locate-fab {
  right: 24rpx;
}

.refresh-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  border: 5rpx solid #17231f;
  border-left-color: transparent;
  border-radius: 50%;
  box-sizing: border-box;
  filter: drop-shadow(0 2rpx 6rpx rgba(255, 255, 255, 0.9)) drop-shadow(0 6rpx 12rpx rgba(20, 35, 31, 0.22));
}

.refresh-icon::after {
  content: "";
  position: absolute;
  right: -4rpx;
  top: 1rpx;
  width: 0;
  height: 0;
  border-left: 13rpx solid #17231f;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  transform: rotate(42deg);
}

.locate-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  border: 5rpx solid #17231f;
  border-radius: 50%;
  box-sizing: border-box;
  filter: drop-shadow(0 2rpx 6rpx rgba(255, 255, 255, 0.9)) drop-shadow(0 6rpx 12rpx rgba(20, 35, 31, 0.22));
}

.locate-icon::before,
.locate-icon::after {
  content: "";
  position: absolute;
  background: #17231f;
}

.locate-icon::before {
  left: 50%;
  top: -18rpx;
  width: 5rpx;
  height: 68rpx;
  transform: translateX(-50%);
}

.locate-icon::after {
  left: -18rpx;
  top: 50%;
  width: 68rpx;
  height: 5rpx;
  transform: translateY(-50%);
}

.locate-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 1;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #17231f;
  transform: translate(-50%, -50%);
}

.map-page .list-fab {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  z-index: 3;
  height: 78rpx;
  min-width: 154rpx;
  width: auto;
  max-width: none;
  margin-left: 0;
  margin-right: 0;
  padding: 0 26rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #e56d3f, #c84c30);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 36rpx rgba(125, 47, 31, 0.34);
}

.drawer-mask {
  position: absolute;
  inset: 0;
  z-index: 4;
  background: rgba(13, 24, 21, 0.36);
}

.list-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
  height: 62vh;
  padding: 18rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 20rpx 20rpx 0 0;
  background:
    linear-gradient(180deg, #f9fbf8, #eef2ef);
  box-sizing: border-box;
  transform: translateY(104%);
  transition: transform 220ms ease;
  box-shadow: 0 -22rpx 56rpx rgba(12, 22, 19, 0.18);
}

.list-drawer.open {
  transform: translateY(0);
}

.drawer-grip {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  background: #c9d2ce;
}

.drawer-head {
  margin-bottom: 18rpx;
}

.post-list {
  height: calc(62vh - 172rpx - env(safe-area-inset-bottom));
}

.post-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.post-content {
  min-width: 0;
}

.post-main {
  display: grid;
  grid-template-columns: 1fr 52rpx;
  gap: 14rpx;
  align-items: center;
}

.post-text {
  min-width: 0;
}

.card-top {
  margin-top: 16rpx;
  margin-bottom: 0;
}

.post-title {
  color: #14231f;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.28;
}

.post-meta {
  margin-top: 10rpx;
  color: #66736d;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.signals {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(26, 46, 41, 0.08);
  color: #485650;
  font-size: 24rpx;
}

.post-card .mark-button {
  width: 52rpx;
  min-width: 52rpx;
  max-width: 52rpx;
  height: 52rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  background: transparent;
}

.mark-arrow {
  width: 26rpx;
  height: 26rpx;
  border-top: 6rpx solid #1f6658;
  border-right: 6rpx solid #1f6658;
  transform: rotate(45deg);
}

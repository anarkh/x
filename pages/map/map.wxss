.map-page {
  min-height: 100vh;
  background: #10211c;
  position: relative;
  overflow: hidden;
}

.task-map {
  width: 100%;
  height: 100vh;
}

.map-tool-row {
  position: absolute;
  right: 24rpx;
  bottom: calc(150rpx + env(safe-area-inset-bottom));
  z-index: 3;
  display: grid;
  grid-template-columns: repeat(2, 68rpx);
  gap: 20rpx;
  align-items: center;
  justify-items: center;
}

.map-tool-button {
  position: relative;
  width: 68rpx;
  min-width: 68rpx;
  max-width: 68rpx;
  height: 68rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 50%;
  background: transparent;
  box-shadow: none;
}

.map-tool-button:active {
  opacity: 0.72;
}

.clear-tool-button {
  background: transparent;
}

.map-tool-icon {
  display: block;
  width: 52rpx;
  height: 52rpx;
  filter: drop-shadow(0 2rpx 2rpx rgba(255, 255, 255, 0.78));
}

.locate-icon {
  width: 60rpx;
  height: 60rpx;
}

.discover-tool-button {
  border-color: rgba(200, 76, 48, 0.18);
  background: linear-gradient(135deg, #e56d3f, #c84c30);
  box-shadow: 0 12rpx 28rpx rgba(125, 47, 31, 0.26);
}

.discover-tool-button:active {
  background: rgba(229, 109, 63, 0.96);
  opacity: 1;
}

.discover-tool-button .map-tool-icon {
  filter: none;
}

.search-icon {
  width: 42rpx;
  height: 42rpx;
}

.map-page .list-fab {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  z-index: 3;
  width: 78rpx;
  min-width: 78rpx;
  max-width: 78rpx;
  height: 78rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 50%;
  border: 1rpx solid rgba(22, 49, 42, 0.1);
  background: rgba(248, 250, 247, 0.96);
  color: #17332d;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 34rpx rgba(13, 24, 21, 0.16);
}

.selected-card {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(246rpx + env(safe-area-inset-bottom));
  z-index: 4;
  padding: 26rpx;
  border-color: rgba(22, 49, 42, 0.12);
  background: rgba(251, 252, 250, 0.97);
  box-shadow: 0 22rpx 54rpx rgba(13, 24, 21, 0.2);
}

.selected-head {
  display: grid;
  grid-template-columns: 1fr 52rpx;
  gap: 16rpx;
  align-items: start;
}

.selected-head.with-thumb {
  grid-template-columns: 1fr 108rpx 52rpx;
}

.selected-main {
  min-width: 0;
}

.selected-thumb {
  width: 108rpx;
  height: 108rpx;
  border-radius: 8rpx;
  background: #eef1ef;
}

.selected-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.selected-title {
  color: #14231f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
}

.selected-meta {
  margin-top: 10rpx;
  color: #66736d;
  font-size: 24rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-actions {
  margin-top: 20rpx;
}

.selected-detail {
  width: 100%;
  height: 76rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #143e37, #25705f);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.selected-close {
  width: 52rpx;
  min-width: 52rpx;
  max-width: 52rpx;
  height: 52rpx;
  border-radius: 8rpx;
  background: #eef1ef;
  color: #5f6f68;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  z-index: 4;
  background: rgba(13, 24, 21, 0.42);
}

.list-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  z-index: 5;
  height: 65vh;
  padding: 18rpx 24rpx calc(26rpx + env(safe-area-inset-bottom));
  border-radius: 20rpx 20rpx 0 0;
  background:
    linear-gradient(180deg, #fbfcfa, #eef2ef);
  box-sizing: border-box;
  transform: translateY(104%);
  transition: transform 220ms ease;
  box-shadow: 0 -24rpx 58rpx rgba(12, 22, 19, 0.2);
}

.list-drawer.open {
  transform: translateY(0);
}

.drawer-grip {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 999rpx;
  background: #c9d2ce;
}

.drawer-head {
  margin-bottom: 18rpx;
}

.filter-bar {
  width: 100%;
  margin-bottom: 18rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  height: 60rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #40504a;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-chip.active {
  border-color: rgba(31, 102, 88, 0.32);
  background: #1b5f52;
  color: #ffffff;
}

.post-list {
  height: calc(65vh - 258rpx - env(safe-area-inset-bottom));
}

.post-card {
  padding: 26rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.post-content {
  min-width: 0;
}

.post-main {
  display: grid;
  grid-template-columns: 1fr 52rpx;
  gap: 14rpx;
  align-items: center;
}

.post-main.with-thumb {
  grid-template-columns: 104rpx 1fr 52rpx;
}

.post-thumb {
  width: 104rpx;
  height: 104rpx;
  border-radius: 8rpx;
  background: #eef1ef;
}

.post-text {
  min-width: 0;
}

.card-top {
  margin-top: 16rpx;
  margin-bottom: 0;
}

.card-tags {
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.post-title {
  color: #14231f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.28;
}

.post-meta {
  margin-top: 10rpx;
  color: #66736d;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.signals {
  display: grid;
  grid-template-columns: 1.35fr 0.75fr 1fr;
  gap: 8rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(26, 46, 41, 0.08);
  color: #4a5b53;
  font-size: 24rpx;
}

.signals text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-card .mark-button {
  width: 52rpx;
  min-width: 52rpx;
  max-width: 52rpx;
  height: 52rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 8rpx;
  background: #e8f2ee;
}

.mark-arrow {
  width: 26rpx;
  height: 26rpx;
  border-top: 6rpx solid #1f6658;
  border-right: 6rpx solid #1f6658;
  transform: rotate(45deg);
}

.empty-panel {
  padding: 36rpx 28rpx;
  margin-top: 6rpx;
}

.empty-title {
  margin-bottom: 10rpx;
  color: #16231f;
  font-size: 30rpx;
  font-weight: 900;
}

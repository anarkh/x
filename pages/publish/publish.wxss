.page {
  padding-bottom: calc(286rpx + env(safe-area-inset-bottom));
}

.page-head {
  position: relative;
  min-height: 92rpx;
  padding: 18rpx 0 12rpx 104rpx;
}

.head-mark {
  position: absolute;
  left: 0;
  top: 18rpx;
  width: 78rpx;
  height: 78rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #173b33, #1f6658);
  color: #f7fbf7;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 78rpx;
  text-align: center;
  box-shadow: 0 14rpx 28rpx rgba(23, 32, 29, 0.14);
}

.form-card {
  padding: 30rpx 28rpx;
  border: 1rpx solid rgba(31, 63, 52, 0.1);
  border-radius: 18rpx;
  background: rgba(255, 254, 250, 0.96);
  box-shadow: 0 12rpx 30rpx rgba(23, 32, 29, 0.06);
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0;
  border: 0;
  background: transparent;
}

.form-section + .form-section {
  margin-top: 10rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(31, 63, 52, 0.1);
}

.form-section-head {
  padding-bottom: 0;
  border-bottom: 0;
}

.form-section-title {
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.field {
  min-width: 0;
}

.field-meta {
  margin-top: 8rpx;
  color: #697970;
  font-size: 22rpx;
  line-height: 1.35;
  text-align: right;
}

.login-notice {
  padding: 22rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.14);
  border-radius: 14rpx;
  background: #f1f8f4;
}

.notice-title {
  margin-bottom: 8rpx;
  color: #173b33;
  font-size: 28rpx;
  font-weight: 900;
}

.label {
  margin-bottom: 12rpx;
  color: #2e423a;
  font-size: 24rpx;
  font-weight: 900;
}

.input,
.textarea,
.picker {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(26, 46, 41, 0.13);
  border-radius: 14rpx;
  background: #fbfaf4;
  color: #14211d;
  font-size: 28rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.input,
.picker {
  height: 88rpx;
  padding: 0 22rpx;
  line-height: 88rpx;
}

.textarea {
  min-height: 178rpx;
  padding: 20rpx 22rpx;
  line-height: 1.5;
}

.input:focus,
.textarea:focus,
.picker:active {
  border-color: rgba(31, 102, 88, 0.34);
  background: #ffffff;
}

.picker {
  position: relative;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.image-cell,
.image-add {
  position: relative;
  width: 100%;
  height: 168rpx;
  min-width: 0;
  margin: 0;
  padding: 0;
  border-radius: 14rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.image-cell {
  background: #f0eee7;
}

.image-preview {
  display: block;
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 44rpx;
  min-width: 44rpx;
  max-width: 44rpx;
  height: 44rpx;
  padding: 0;
  border-radius: 999rpx;
  background: rgba(13, 24, 21, 0.72);
  color: #ffffff;
  font-size: 34rpx;
  line-height: 40rpx;
}

.image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed rgba(31, 102, 88, 0.34);
  background: #f1f8f4;
  color: #1f6658;
}

.add-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(31, 102, 88, 0.42);
  font-size: 40rpx;
  font-weight: 500;
  line-height: 42rpx;
}

.add-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.1;
}

.image-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
}

.picker::after {
  content: "";
  position: absolute;
  right: 24rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid #5f6f68;
  border-bottom: 4rpx solid #5f6f68;
  transform: translateY(-66%) rotate(45deg);
}

.intent-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  width: 100%;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.category-option {
  width: 100%;
  min-width: 0;
  height: 78rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.16);
  border-radius: 14rpx;
  background: #fbfaf4;
  color: #3e5149;
  font-size: 25rpx;
  font-weight: 900;
}

.category-option.active {
  border-color: rgba(31, 102, 88, 0.34);
  background: #eaf4ef;
  color: #1b5f52;
  box-shadow: inset 0 0 0 2rpx rgba(31, 102, 88, 0.08);
}

.intent-tab {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  margin-left: 0;
  margin-right: 0;
  height: 76rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 14rpx;
  background: #fbfaf4;
  color: #3e5149;
  font-size: 26rpx;
  font-weight: 900;
}

.intent-tab.active {
  border-color: rgba(31, 102, 88, 0.32);
  background: linear-gradient(135deg, #143e37, #1f6658);
  color: #ffffff;
}

.location-check {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 168rpx;
  gap: 16rpx;
  align-items: center;
  padding: 18rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.14);
  border-radius: 14rpx;
  background: #fbfaf4;
}

.location-check.ready {
  border-color: rgba(31, 102, 88, 0.28);
  background: #eaf4ef;
}

.location-check.failed {
  border-color: rgba(167, 53, 39, 0.18);
  background: #fff4ef;
}

.location-copy {
  min-width: 0;
}

.location-title {
  color: #14211d;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.3;
}

.location-note {
  margin-top: 6rpx;
  color: #697970;
  font-size: 23rpx;
  line-height: 1.4;
}

.location-button {
  width: 168rpx;
  min-width: 168rpx;
  max-width: 168rpx;
  height: 68rpx;
  padding: 0;
  border-radius: 14rpx;
  background: #fffefa;
  color: #1f6658;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 68rpx;
}

.expiry-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.expiry-option {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  padding: 0;
  border: 1rpx solid rgba(31, 102, 88, 0.16);
  border-radius: 14rpx;
  background: #fbfaf4;
  color: #3e5149;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.expiry-option.active {
  border-color: rgba(31, 102, 88, 0.34);
  background: #eaf4ef;
  color: #1b5f52;
  box-shadow: inset 0 0 0 2rpx rgba(31, 102, 88, 0.08);
}

.custom-expiry {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.14);
  border-radius: 16rpx;
  background: #fffefa;
}

.custom-expiry-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.custom-expiry-title {
  color: #20352f;
  font-size: 25rpx;
  font-weight: 900;
}

.custom-expiry-text {
  color: #697970;
  font-size: 23rpx;
  line-height: 1.35;
  text-align: right;
}

.custom-expiry-controls {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.custom-expiry-picker {
  height: 72rpx;
  border-radius: 14rpx;
  background: #f3f2eb;
  color: #1f6658;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 72rpx;
  text-align: center;
}

.custom-expiry-error {
  margin-top: 10rpx;
  color: #b45b2a;
  font-size: 23rpx;
  line-height: 1.35;
}

.publish-action .bottom-action-inner {
  grid-template-columns: minmax(0, 1fr) 186rpx;
}

.publish-action .bottom-action-title {
  color: #173b33;
}

.publish-action .bottom-action-note {
  color: #5f7169;
}

.publish-action .primary-button[disabled] {
  opacity: 1;
  background: #dce8e2;
  color: #4c665d;
  box-shadow: none;
}

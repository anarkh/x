.page {
  padding-bottom: calc(146rpx + env(safe-area-inset-bottom));
}

.page-head {
  position: relative;
  min-height: 92rpx;
  padding: 22rpx 0 12rpx 106rpx;
}

.head-mark {
  position: absolute;
  left: 0;
  top: 18rpx;
  width: 76rpx;
  height: 76rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #17231f, #1f6658);
  color: #f7fbf7;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
  box-shadow: 0 14rpx 28rpx rgba(23, 32, 29, 0.16);
}

.form-card {
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.98);
}

.label {
  margin-bottom: 12rpx;
  color: #304940;
  font-size: 24rpx;
  font-weight: 900;
}

.input,
.textarea,
.picker {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(26, 46, 41, 0.13);
  border-radius: 8rpx;
  background: #fbfcfa;
  color: #17201d;
  font-size: 28rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.input,
.picker {
  height: 88rpx;
  padding: 0 22rpx;
  line-height: 88rpx;
}

.textarea {
  min-height: 178rpx;
  padding: 20rpx 22rpx;
  line-height: 1.5;
}

.input:focus,
.textarea:focus,
.picker:active {
  border-color: rgba(31, 102, 88, 0.34);
  background: #ffffff;
}

.picker {
  position: relative;
}

.picker::after {
  content: "";
  position: absolute;
  right: 24rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  border-right: 4rpx solid #5f6f68;
  border-bottom: 4rpx solid #5f6f68;
  transform: translateY(-66%) rotate(45deg);
}

.intent-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  width: 100%;
}

.intent-tab {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  margin-left: 0;
  margin-right: 0;
  height: 76rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 8rpx;
  background: #fbfcfa;
  color: #40524c;
  font-size: 26rpx;
  font-weight: 900;
}

.intent-tab.active {
  border-color: rgba(31, 102, 88, 0.32);
  background: linear-gradient(135deg, #143e37, #25705f);
  color: #ffffff;
}

.page-head {
  position: relative;
  padding: 18rpx 0 8rpx 92rpx;
}

.head-mark {
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 68rpx;
  height: 68rpx;
  border-radius: 8rpx;
  background: #17231f;
  color: #f7fbf7;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 68rpx;
  text-align: center;
}

.form-card {
  padding: 28rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #40524c;
  font-size: 24rpx;
  font-weight: 900;
}

.input,
.textarea,
.picker {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(26, 46, 41, 0.12);
  border-radius: 8rpx;
  background: #f8faf7;
  color: #17201d;
  font-size: 28rpx;
}

.input,
.picker {
  height: 88rpx;
  padding: 0 22rpx;
  line-height: 88rpx;
}

.textarea {
  min-height: 178rpx;
  padding: 20rpx 22rpx;
  line-height: 1.5;
}

.intent-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.intent-tab {
  height: 76rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 8rpx;
  background: #f8faf7;
  color: #40524c;
  font-size: 26rpx;
  font-weight: 900;
}

.intent-tab.active {
  border-color: rgba(31, 102, 88, 0.32);
  background: #1f6658;
  color: #ffffff;
}

<view class="page stack">
  <view class="page-head">
    <view class="head-mark">发</view>
    <view class="title">发布街区任务</view>
    <view class="muted">发布到{{appInfo.shortName}}，自动使用你的当前位置</view>
  </view>

  <view class="panel form-card stack">
    <view wx:if="{{isGuest}}" class="login-notice">
      <view class="notice-title">登录后才能发布</view>
      <view class="muted">发布时会记录你的用户身份，方便在“我的发布”里管理任务。</view>
    </view>

    <view class="publish-ready">
      <view class="ready-head">
        <view>
          <view class="ready-title">发布准备</view>
          <view class="ready-note">按顺序补齐，底部按钮会实时提示下一步。</view>
        </view>
        <view class="ready-count">{{readiness.completionText}}</view>
      </view>
      <view class="ready-grid">
        <view wx:for="{{readiness.items}}" wx:key="key" class="ready-item {{item.done ? 'done' : ''}}">
          <view class="ready-dot"></view>
          <view class="ready-copy">
            <view class="ready-label">{{item.label}}</view>
            <view class="ready-value">{{item.value}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-section-head">
        <view class="form-section-title">任务内容</view>
        <view class="form-section-note">先说清楚附近的人需要知道什么</view>
      </view>
      <view class="field">
        <view class="label">标题</view>
        <input class="input" maxlength="32" placeholder="{{activeGuide.titlePlaceholder}}" value="{{form.title}}" data-field="title" bindinput="onInput" />
        <view class="field-meta">{{form.title.length}}/32</view>
      </view>

      <view class="field">
        <view class="label">详情</view>
        <textarea class="textarea" maxlength="180" placeholder="{{activeGuide.bodyPlaceholder}}" value="{{form.body}}" data-field="body" bindinput="onInput" />
        <view class="field-meta">{{form.body.length}}/180</view>
      </view>

      <view class="field">
        <view class="label">图片</view>
        <view class="image-grid">
          <view wx:for="{{imageItems}}" wx:key="path" class="image-cell">
            <image class="image-preview" src="{{item.path}}" mode="aspectFill" lazy-load="{{true}}" data-index="{{index}}" bindtap="previewImage" />
            <button class="image-remove" aria-label="删除图片" data-index="{{index}}" catchtap="removeImage">×</button>
          </view>
          <button wx:if="{{canAddImage}}" class="image-add" bindtap="chooseImages">
            <view class="add-icon">+</view>
            <view class="add-text">上传图片</view>
          </button>
        </view>
        <view class="image-hint muted">最多{{maxImageCount}}张，单张小于{{maxImageSizeText}}，建议上传现场或物品特征图。</view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-section-head">
        <view class="form-section-title">分类与位置</view>
        <view class="form-section-note">分类、位置和有效期决定附近的人如何看到它</view>
      </view>
      <view class="field">
        <view class="label">类型</view>
        <view class="category-grid">
          <button
            wx:for="{{categories}}"
            wx:key="value"
            class="category-option {{categoryIndex === index ? 'active' : ''}}"
            data-index="{{index}}"
            bindtap="onCategoryTap"
          >
            {{item.label}}
          </button>
        </view>
      </view>

      <view wx:if="{{form.category === 'lost_found'}}" class="field">
        <view class="label">方向</view>
        <view class="intent-tabs">
          <button
            wx:for="{{lostFoundIntents}}"
            wx:key="value"
            class="intent-tab {{intentIndex === index ? 'active' : ''}}"
            data-index="{{index}}"
            bindtap="onIntentChange"
          >
            {{item.label}}
          </button>
        </view>
      </view>

      <view class="field">
        <view class="label">当前位置</view>
        <view class="location-check {{locationStatus}}">
          <view class="location-copy">
            <view class="location-title">{{locationStatus === 'ready' ? '位置已确认' : locationStatus === 'failed' ? '位置未确认' : locationStatus === 'locating' ? '正在确认位置' : '使用微信当前位置'}}</view>
            <view class="location-note">{{locationSummary}}</view>
          </view>
          <button class="location-button" loading="{{locationStatus === 'locating'}}" disabled="{{locationStatus === 'locating'}}" bindtap="confirmLocation">{{readiness.locationActionText}}</button>
        </view>
      </view>

      <view class="field">
        <view class="label">地点补充</view>
        <input class="input" maxlength="40" placeholder="{{activeGuide.placePlaceholder}}" value="{{form.placeName}}" data-field="placeName" bindinput="onInput" />
      </view>

      <view class="field">
        <view class="label">有效期</view>
        <view class="expiry-grid">
          <button
            wx:for="{{expiryOptions}}"
            wx:key="value"
            class="expiry-option {{expiryIndex === index ? 'active' : ''}}"
            data-index="{{index}}"
            bindtap="onExpiryTap"
          >
            {{item.label}}
          </button>
        </view>
        <view wx:if="{{isCustomExpiry}}" class="custom-expiry">
          <view class="custom-expiry-head">
            <view class="custom-expiry-title">截止时间</view>
            <view class="custom-expiry-text">{{customExpiryText}}</view>
          </view>
          <view class="custom-expiry-controls">
            <picker mode="date" value="{{customExpiryDate}}" start="{{customExpiryStartDate}}" bindchange="onCustomExpiryDateChange">
              <view class="custom-expiry-picker">{{customExpiryDate}}</view>
            </picker>
            <picker mode="time" value="{{customExpiryTime}}" bindchange="onCustomExpiryTimeChange">
              <view class="custom-expiry-picker">{{customExpiryTime}}</view>
            </picker>
          </view>
          <view wx:if="{{customExpiryError}}" class="custom-expiry-error">{{customExpiryError}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-action publish-action">
    <view class="bottom-action-inner">
      <view>
        <view class="bottom-action-title">{{readiness.title}}</view>
        <view class="bottom-action-note">{{readiness.note}}</view>
      </view>
      <button class="primary-button" loading="{{submitting}}" disabled="{{readiness.actionDisabled}}" bindtap="submit">{{readiness.buttonText}}</button>
    </view>
  </view>
</view>

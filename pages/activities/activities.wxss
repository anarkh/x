.list-page {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.page-head {
  position: relative;
  padding: 22rpx 0 12rpx;
}

.stat-panel {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 28rpx 0;
  background: #fffefa;
  text-align: center;
}

.metric {
  color: #1b5f52;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.08;
}

.stat-item + .stat-item {
  border-left: 1rpx solid rgba(26, 46, 41, 0.1);
}

.empty-panel {
  padding: 30rpx;
}

.empty-title {
  margin-bottom: 8rpx;
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.empty-action {
  margin-top: 24rpx;
}

.activity-card {
  display: grid;
  grid-template-columns: 144rpx 1fr;
  gap: 18rpx;
  align-items: center;
  padding: 24rpx;
  background: #fffefa;
}

.activity-card:active {
  opacity: 0.76;
}

.activity-main {
  min-width: 0;
}

.compact-title {
  margin-bottom: 8rpx;
  color: #14211d;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.28;
}

.activity-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  background: #f0eee7;
  color: #697970;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
}

.activity-mark.done {
  background: #e4f0e9;
  color: #28584e;
}

.activity-mark.warn {
  background: #fff2da;
  color: #915709;
}

.activity-mark.danger {
  background: #ffe9e2;
  color: #a73527;
}

.list-page {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.page-head {
  position: relative;
  min-height: 92rpx;
  padding: 22rpx 0 12rpx 106rpx;
}

.head-mark {
  position: absolute;
  left: 0;
  top: 18rpx;
  width: 76rpx;
  height: 76rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #17231f, #1f6658);
  color: #f7fbf7;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
  box-shadow: 0 14rpx 28rpx rgba(23, 32, 29, 0.16);
}

.stat-panel {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 28rpx 0;
  background: rgba(255, 255, 255, 0.98);
  text-align: center;
}

.metric {
  color: #1b5f52;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.08;
}

.stat-item + .stat-item {
  border-left: 1rpx solid rgba(26, 46, 41, 0.1);
}

.empty-panel {
  padding: 30rpx;
}

.empty-title {
  margin-bottom: 8rpx;
  color: #16231f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.empty-action {
  margin-top: 24rpx;
}

.activity-card {
  display: grid;
  grid-template-columns: 144rpx 1fr;
  gap: 18rpx;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.98);
}

.activity-card:active {
  opacity: 0.76;
}

.activity-main {
  min-width: 0;
}

.compact-title {
  margin-bottom: 8rpx;
  color: #16231f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.28;
}

.activity-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  background: #eef1ef;
  color: #5f6f68;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
}

.activity-mark.done {
  background: #dcebe5;
  color: #28584e;
}

.activity-mark.warn {
  background: #fff1d7;
  color: #915709;
}

.activity-mark.danger {
  background: #ffe8e2;
  color: #a73527;
}

page {
  min-height: 100%;
  background: #edf1ec;
  color: #17201d;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  box-sizing: border-box;
  line-height: 1;
  width: auto;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 28rpx;
  background:
    linear-gradient(180deg, rgba(31, 102, 88, 0.12), rgba(237, 241, 236, 0) 288rpx),
    linear-gradient(135deg, rgba(229, 109, 63, 0.08), rgba(229, 109, 63, 0) 360rpx),
    #edf1ec;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  justify-content: space-between;
}

.panel {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(22, 49, 42, 0.1);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 40rpx rgba(23, 32, 29, 0.08);
}

.muted {
  color: #5f6f68;
  font-size: 24rpx;
  line-height: 1.5;
}

.title {
  color: #111f1b;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.12;
  letter-spacing: 0;
}

.section-title {
  color: #14231f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 17rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.16);
  border-radius: 6rpx;
  background: #ecf6f1;
  color: #1b5f52;
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: inset 0 -1rpx 0 rgba(31, 102, 88, 0.08);
}

.tag.warn {
  border-color: rgba(177, 112, 24, 0.2);
  background: #fff1d7;
  color: #915709;
}

.tag.danger {
  border-color: rgba(178, 54, 39, 0.18);
  background: #ffe8e2;
  color: #a73527;
}

.tag.done {
  border-color: rgba(31, 102, 88, 0.18);
  background: #dcebe5;
  color: #28584e;
}

.tag.neutral {
  border-color: rgba(102, 115, 109, 0.18);
  background: #eef1ef;
  color: #5f6f68;
}

.primary-button,
.secondary-button {
  width: 100%;
  height: 92rpx;
  border-radius: 8rpx;
  font-weight: 900;
  font-size: 30rpx;
  transition: opacity 160ms ease, transform 160ms ease;
}

.primary-button {
  color: #ffffff;
  background: linear-gradient(135deg, #143e37, #25705f);
  box-shadow: 0 18rpx 34rpx rgba(31, 102, 88, 0.24);
}

.primary-button:active,
.secondary-button:active,
.ghost-button:active {
  opacity: 0.76;
}

.secondary-button {
  border: 1rpx solid rgba(31, 102, 88, 0.2);
  color: #1b5f52;
  background: #e6f2ee;
}

.ghost-button {
  height: 66rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(31, 102, 88, 0.18);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #1b5f52;
  font-size: 26rpx;
  font-weight: 800;
}

button[disabled] {
  opacity: 0.56;
}
